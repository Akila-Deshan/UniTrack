<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.akila.unitrack.controller.MainController"
            prefWidth="1280" prefHeight="870"
            styleClass="root-pane">

    <!-- TOP: Title bar -->
    <top>
        <HBox styleClass="title-bar" alignment="CENTER">
            <Label text="UniTrack  Personal Academic Record Manager"
                   styleClass="title-label"/>
        </HBox>
    </top>

    <!-- LEFT: Add module form -->
    <left>
        <VBox spacing="8" styleClass="left-panel">

            <Label text="Add Module" styleClass="section-title"/>
            <Separator/>

            <Label text="Module Name" styleClass="field-label"/>
            <TextField fx:id="moduleNameField"
                       promptText="e.g. Data Structures"
                       styleClass="input-field"/>

            <Label text="Module Code" styleClass="field-label"/>
            <TextField fx:id="moduleCodeField"
                       promptText="e.g. CCS2300"
                       styleClass="input-field"/>

            <Label text="Credits" styleClass="field-label"/>
            <TextField fx:id="creditsField"
                       promptText="e.g. 3"
                       styleClass="input-field"/>

            <Label text="Grade" styleClass="field-label"/>
            <ComboBox fx:id="gradeComboBox"
                      promptText="Select Grade"
                      maxWidth="Infinity"
                      styleClass="input-field"/>

            <Label text="Semester" styleClass="field-label"/>
            <ComboBox fx:id="semesterComboBox"
                      promptText="Select Semester"
                      maxWidth="Infinity"
                      styleClass="input-field"/>

            <Button text="＋  Add Module"
                    onAction="#handleAddModule"
                    maxWidth="Infinity"
                    styleClass="add-button"/>

            <Label fx:id="statusLabel" text="" wrapText="true" maxWidth="190"/>

            <Separator/>

            <Label text="Overall Progress" styleClass="section-title"/>

            <Label fx:id="cumulativeGPALabel"
                   text="Cumulative GPA: —"
                   styleClass="gpa-label"
                   wrapText="true" maxWidth="190"/>

            <Label fx:id="cumulativeClassLabel"
                   text="Current Class: —"
                   styleClass="class-label"
                   wrapText="true" maxWidth="190"/>

        </VBox>
    </left>

    <!-- CENTER: Semester viewer + module table -->
    <center>
        <VBox spacing="12" styleClass="center-panel">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="View Semester:" styleClass="field-label"/>
                <ComboBox fx:id="viewSemesterComboBox"
                          promptText="Select Semester"
                          styleClass="input-field"/>
                <Button text="View"
                        onAction="#handleViewSemester"
                        styleClass="view-button"/>
                <Button text="Delete Selected"
                        onAction="#handleDeleteModule"
                        styleClass="delete-button"/>
            </HBox>

            <HBox spacing="20" alignment="CENTER_LEFT" styleClass="gpa-bar">
                <Label fx:id="semesterGPALabel"
                       text="Semester GPA: —"
                       styleClass="gpa-label"
                       wrapText="true" maxWidth="250"/>
                <Label text="|" styleClass="divider-label"/>
                <Label fx:id="semesterClassLabel"
                       text="Class: —"
                       styleClass="class-label"
                       wrapText="true" maxWidth="300"/>
            </HBox>

            <TableView fx:id="moduleTable" VBox.vgrow="ALWAYS" styleClass="module-table">
                <columns>
                    <TableColumn fx:id="nameColumn"        text="Module Name"   prefWidth="250"/>
                    <TableColumn fx:id="codeColumn"        text="Code"          prefWidth="110"/>
                    <TableColumn fx:id="creditsColumn"     text="Credits"       prefWidth="80"/>
                    <TableColumn fx:id="gradeColumn"       text="Grade"         prefWidth="80"/>
                    <TableColumn fx:id="gradePointsColumn" text="Grade Points"  prefWidth="110"/>
                </columns>
                <placeholder>
                    <Label text="No modules yet. Select a semester and click View."
                           styleClass="placeholder-text"/>
                </placeholder>
            </TableView>

        </VBox>
    </center>

    <!-- BOTTOM: Academic report -->
    <bottom>
        <VBox spacing="8" styleClass="bottom-panel">

            <Label text="📊  Academic Report" styleClass="section-title"/>

            <TextArea fx:id="academicReportArea"
                      promptText="Academic report appears here when a semester is complete..."
                      editable="false"
                      prefHeight="160"
                      styleClass="report-area"/>
        </VBox>
    </bottom>

</BorderPane>