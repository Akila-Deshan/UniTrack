<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.akila.unitrack.controller.MainController"
            prefWidth="1280" prefHeight="850"
            style="-fx-background-color: #f4f6f9;">

    <!-- TOP: Title bar -->
    <top>
        <HBox style="-fx-background-color: #1a3a5c; -fx-padding: 15px 20px;"
              alignment="CENTER">
            <Label text="UniTrack  Personal Academic Record Manager"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;
                          -fx-text-fill: white; -fx-font-family: 'Segoe UI';"/>
        </HBox>
    </top>

    <!-- LEFT: Add module form -->
    <left>
        <VBox spacing="8"
              style="-fx-background-color: white; -fx-padding: 20px;
                     -fx-pref-width: 230px; -fx-border-color: #e0e0e0;
                     -fx-border-width: 0 1 0 0;">

            <Label text="Add Module"
                   style="-fx-font-size: 15px; -fx-font-weight: bold;
                          -fx-text-fill: #1a3a5c;"/>

            <Separator/>

            <!-- Module Name -->
            <Label text="Module Name"
                   style="-fx-text-fill: #555555; -fx-font-weight: bold;"/>
            <TextField fx:id="moduleNameField"
                       promptText="e.g. Data Structures"
                       style="-fx-background-color: #f4f6f9;
                              -fx-border-color: #d0d0d0;
                              -fx-border-radius: 5px;
                              -fx-background-radius: 5px;
                              -fx-padding: 6px;"/>

            <!-- Module Code -->
            <Label text="Module Code"
                   style="-fx-text-fill: #555555; -fx-font-weight: bold;"/>
            <TextField fx:id="moduleCodeField"
                       promptText="e.g. CCS2300"
                       style="-fx-background-color: #f4f6f9;
                              -fx-border-color: #d0d0d0;
                              -fx-border-radius: 5px;
                              -fx-background-radius: 5px;
                              -fx-padding: 6px;"/>

            <!-- Credits -->
            <Label text="Credits"
                   style="-fx-text-fill: #555555; -fx-font-weight: bold;"/>
            <TextField fx:id="creditsField"
                       promptText="e.g. 3"
                       style="-fx-background-color: #f4f6f9;
                              -fx-border-color: #d0d0d0;
                              -fx-border-radius: 5px;
                              -fx-background-radius: 5px;
                              -fx-padding: 6px;"/>

            <!-- Grade -->
            <Label text="Grade"
                   style="-fx-text-fill: #555555; -fx-font-weight: bold;"/>
            <ComboBox fx:id="gradeComboBox"
                      promptText="Select Grade"
                      maxWidth="Infinity"
                      style="-fx-background-color: #f4f6f9;
                             -fx-border-color: #d0d0d0;
                             -fx-border-radius: 5px;
                             -fx-background-radius: 5px;"/>

            <!-- Semester -->
            <Label text="Semester"
                   style="-fx-text-fill: #555555; -fx-font-weight: bold;"/>
            <ComboBox fx:id="semesterComboBox"
                      promptText="Select Semester"
                      maxWidth="Infinity"
                      style="-fx-background-color: #f4f6f9;
                             -fx-border-color: #d0d0d0;
                             -fx-border-radius: 5px;
                             -fx-background-radius: 5px;"/>

            <!-- Add Button -->
            <Button text="＋  Add Module"
                    onAction="#handleAddModule"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1a3a5c;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 13px;
                           -fx-padding: 8px;
                           -fx-background-radius: 5px;
                           -fx-cursor: hand;"/>

            <!-- Status message -->
            <Label fx:id="statusLabel" text="" wrapText="true"/>

            <Separator/>

            <!-- Overall Progress -->
            <Label text="Overall Progress"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                          -fx-text-fill: #1a3a5c;"/>

            <Label fx:id="cumulativeGPALabel"
                   text="Cumulative GPA: —"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                          -fx-text-fill: #1a3a5c;"/>

            <Label fx:id="cumulativeClassLabel"
                   text="Current Class: —"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #f5821f;"/>

        </VBox>
    </left>

    <!-- CENTER: Semester viewer + module table -->
    <center>
        <VBox spacing="12"
              style="-fx-padding: 20px; -fx-background-color: #f4f6f9;">

            <!-- Semester selector row -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="View Semester:"
                       style="-fx-font-weight: bold; -fx-text-fill: #1a3a5c;"/>
                <ComboBox fx:id="viewSemesterComboBox"
                          promptText="Select Semester"
                          style="-fx-background-color: white;
                                 -fx-border-color: #d0d0d0;
                                 -fx-border-radius: 5px;
                                 -fx-background-radius: 5px;"/>
                <Button text="View"
                        onAction="#handleViewSemester"
                        style="-fx-background-color: #00b4d8;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 5px;
                               -fx-cursor: hand;
                               -fx-padding: 6px 14px;"/>
                <Button text="Delete Selected"
                        onAction="#handleDeleteModule"
                        style="-fx-background-color: #e53935;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 5px;
                               -fx-cursor: hand;
                               -fx-padding: 6px 14px;"/>
            </HBox>

            <!-- Semester GPA row -->
            <HBox spacing="20" alignment="CENTER_LEFT"
                  style="-fx-background-color: white;
                         -fx-padding: 10px 15px;
                         -fx-border-radius: 8px;
                         -fx-background-radius: 8px;
                         -fx-border-color: #e0e0e0;">
                <Label fx:id="semesterGPALabel"
                       text="Semester GPA: —"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;
                              -fx-text-fill: #1a3a5c;"/>
                <Label text="|" style="-fx-text-fill: #d0d0d0;"/>
                <Label fx:id="semesterClassLabel"
                       text="Class: —"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                              -fx-text-fill: #f5821f;"/>
            </HBox>

            <!-- Module table -->
            <TableView fx:id="moduleTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white;
                              -fx-border-color: #e0e0e0;
                              -fx-border-radius: 8px;
                              -fx-background-radius: 8px;">
                <columns>
                    <TableColumn fx:id="nameColumn"
                                 text="Module Name"    prefWidth="250"/>
                    <TableColumn fx:id="codeColumn"
                                 text="Code"           prefWidth="110"/>
                    <TableColumn fx:id="creditsColumn"
                                 text="Credits"        prefWidth="80"/>
                    <TableColumn fx:id="gradeColumn"
                                 text="Grade"          prefWidth="80"/>
                    <TableColumn fx:id="gradePointsColumn"
                                 text="Grade Points"   prefWidth="110"/>
                </columns>
                <placeholder>
                    <Label text="No modules yet. Select a semester and click View."
                           style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>

        </VBox>
    </center>

    <!-- BOTTOM: Academic report -->
    <bottom>
        <VBox spacing="8"
              style="-fx-padding: 15px 20px;
                     -fx-background-color: white;
                     -fx-border-color: #e0e0e0;
                     -fx-border-width: 1 0 0 0;">

            <Label text="📊  Academic Report"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                          -fx-text-fill: #1a3a5c;"/>

            <TextArea fx:id="academicReportArea"
                      promptText="Academic report appears here when a semester is complete..."
                      editable="false"
                      prefHeight="160"
                      style="-fx-background-color: #1a3a5c;
                             -fx-text-fill: black;
                             -fx-font-family: 'Consolas';
                             -fx-font-size: 12px;
                             -fx-border-radius: 8px;
                             -fx-background-radius: 8px;
                             -fx-padding: 10px;"/>
        </VBox>
    </bottom>

</BorderPane>